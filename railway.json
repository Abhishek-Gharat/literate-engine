{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "npm start",
    "healthchecks": {
      "enabled": true,
      "interval": 10000,
      "timeout": 5000,
      "path": "/health"
    }
  },
  "volumes": [
    {
      "name": "data",
      "path": "/app/data",
      "size": "1GB"
    }
  ]
}

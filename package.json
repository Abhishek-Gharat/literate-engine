{
  "name": "reactviz",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.0.0"
  },
"scripts": {
  "start": "node server/index.js",
  "dev": "vite",
  "dev:api": "node server/index.js",
  "build": "vite build",
  "lint": "eslint .",
  "test:api": "node --test server/__tests__/*.test.js src/analysis/*.test.js src/services/*.test.js src/utils/*.test.js",

  "test:e2e": "playwright test",
  "test:e2e:ui": "playwright test --ui",
  "preview": "vite preview"
},
  "dependencies": {
    "@babel/parser": "^7.29.7",
    "@xyflow/react": "^12.10.1",
    "better-sqlite3": "^11.0.0",
